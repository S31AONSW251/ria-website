\n/* Medium stars — mid layer */\r\n\r\n.star-layer-b {\r\n  background-image:\r\n    radial-gradient(circle, rgba(255,255,255,0.72) 0 1.1px, transparent 1.8px),\r\n    radial-gradient(circle, rgba(176,206,255,0.4) 0 1px, transparent 1.6px);\r\n  background-size: 240px 240px, 380px 380px;\r\n  background-position: 36px 18px, 160px 200px;\r\n  animation: star-drift-b 150s linear infinite;\r\n  opacity: 0.45;\r\n}\r\n\r\n/* Large/far stars — slowest parallax */\r\n\r\n.star-layer-c {\r\n  background-image:\r\n    radial-gradient(circle, rgba(255,255,255,0.5) 0 1.3px, transparent 2.2px),\r\n    radial-gradient(circle, rgba(150,190,255,0.28) 0 1px, transparent 1.8px);\r\n  background-size: 420px 420px, 600px 600px;\r\n  background-position: 80px 60px, 300px 340px;\r\n  animation: star-drift-c 220s linear infinite;\r\n  opacity: 0.32;\r\n}\r\n\r\n/* Cosmic dust / atmospheric mist */\r\n\r\n.star-mist {\r\n  position: absolute;\r\n  inset: 0;\r\n  pointer-events: none;\r\n  background:\r\n    radial-gradient(ellipse at 20% 15%, rgba(56, 100, 200, 0.05) 0%, transparent 55%),\r\n    radial-gradient(ellipse at 80% 70%, rgba(30, 60, 160, 0.04) 0%, transparent 50%),\r\n    radial-gradient(ellipse at 55% 45%, rgba(18, 36, 100, 0.03) 0%, transparent 60%);\r\n  animation: mist-breathe 55s ease-in-out infinite alternate;\r\n}\r\n\r\n/* Subtle radial warm glow at hero top */\r\n\r\n.star-hero-glow {\r\n  position: absolute;\r\n  top: -10%;\r\n  left: 50%;\r\n  transform: translateX(-50%);\r\n  width: 80vw;\r\n  height: 60vh;\r\n  pointer-events: none;\r\n  background: radial-gradient(ellipse at center, rgba(30, 58, 138, 0.12) 0%, transparent 65%);\r\n  filter: blur(40px);\r\n}\r\n\r\n@keyframes star-drift-a {\r\n  from { transform: translate3d(0, 0, 0); }\r\n  to   { transform: translate3d(-128px, -128px, 0); }\r\n}\r\n\r\n@keyframes star-drift-b {\r\n  from { transform: translate3d(0, 0, 0); }\r\n  to   { transform: translate3d(-240px, -190px, 0); }\r\n}\r\n\r\n@keyframes star-dri